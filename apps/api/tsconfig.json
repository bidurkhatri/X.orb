{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@xorb/agent-core": ["../../packages/agent-core/src"],
      "@xorb/types": ["../../packages/xorb-types/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "api"]
}
