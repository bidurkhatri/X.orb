# Environment Configuration for SylOS Blockchain OS

# Application Configuration
VITE_APP_VERSION=1.0.0
VITE_NODE_ENV=development

# API Configuration
VITE_API_BASE_URL=http://localhost:3000

# Supabase Configuration (Replace with your actual values)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Wallet Connect Configuration
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Monitoring and Analytics (Optional)
VITE_SENTRY_DSN=your_sentry_dsn_here

# Security and Feature Flags
VITE_ENABLE_ERROR_LOGGING=true
VITE_ENABLE_ANALYTICS=false
VITE_CSP_ENABLED=false
VITE_SECURITY_HEADERS_ENABLED=false

# Development flags
VITE_ENABLE_DEV_TOOLS=true
VITE_ENABLE_MOCK_DATA=true

# Production Environment Variables (for production builds)
# Uncomment and configure for production deployments

# VITE_NODE_ENV=production
# VITE_API_BASE_URL=https://api.sylos.io
# VITE_ENABLE_ERROR_LOGGING=true
# VITE_ENABLE_ANALYTICS=true
# VITE_CSP_ENABLED=true
# VITE_SECURITY_HEADERS_ENABLED=true
# VITE_ENABLE_DEV_TOOLS=false
# VITE_ENABLE_MOCK_DATA=false