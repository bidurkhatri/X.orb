{
  "name": "sylos-blockchain-os",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Next-generation blockchain operating system",
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite --mode development",
    "dev:staging": "vite --mode staging",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "build:analyze": "vite build --mode staging --mode analyze",
    "preview": "vite preview",
    "preview:staging": "vite preview --mode staging",
    "preview:prod": "vite preview --mode production",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "format": "prettier --write src/**/*.{ts,tsx,js,jsx,json,css,md}",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "security:audit": "npm audit --audit-level moderate",
    "security:scan": "npm audit --audit-level moderate && snyk test",
    "security:fix": "npm audit fix",
    "performance:analyze": "vite-bundle-analyzer dist",
    "clean": "rimraf dist coverage .nyc_output",
    "clean:all": "rimraf dist coverage .nyc_output node_modules",
    "deploy:staging": "npm run build:staging && npm run deploy:push",
    "deploy:production": "npm run build && npm run deploy:push",
    "deploy:push": "echo 'Deploying to server...' && ./scripts/deploy.sh",
    "health-check": "node scripts/health-check.js",
    "monitor": "node scripts/monitor.js",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.0",
    "@monaco-editor/react": "^4.7.0",
    "@rainbow-me/rainbowkit": "^2.1.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.56.0",
    "@tanstack/react-query-devtools": "^5.56.0",
    "@toruslabs/tss-dkls-lib": "^4.1.0",
    "@web3-storage/w3up-client": "^17.3.0",
    "@web3auth/base": "^9.7.0",
    "@web3auth/ethereum-provider": "^9.7.0",
    "@web3auth/modal": "^9.7.0",
    "@web3auth/mpc-core-kit": "^3.5.0",
    "@web3auth/web3auth-wagmi-connector": "^7.0.0",
    "@xmtp/xmtp-js": "^13.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.6.0",
    "buffer": "^6.0.3",
    "clsx": "^2.0.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.0.0",
    "ethers": "^6.13.0",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.454.0",
    "pyodide": "^0.29.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.48.0",
    "react-router-dom": "^6.8.0",
    "sonner": "^1.2.0",
    "tailwind-merge": "^2.0.0",
    "uuid": "^13.0.0",
    "viem": "^2.21.0",
    "wagmi": "^2.12.0",
    "web3-utils": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/crypto-js": "^4.2.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "autoprefixer": "^10.4.18",
    "chrome-launcher": "^1.0.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "husky": "^8.0.0",
    "lighthouse": "^11.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.4.35",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.58.0",
    "rollup-plugin-visualizer": "^5.9.0",
    "snyk": "^1.1200.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vite-plugin-html": "^3.2.0",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vitest": "^1.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{js,jsx,ts,tsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run type-check && npm run test"
    }
  }
}
