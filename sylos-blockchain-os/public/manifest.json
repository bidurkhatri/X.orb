{
  "name": "SylOS - Blockchain Operating System",
  "short_name": "SylOS",
  "description": "Next-generation blockchain operating system for productivity, DeFi management, and proof-of-productivity tracking",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0f172a",
  "theme_color": "#8B5CF6",
  "orientation": "any",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "categories": ["productivity", "finance", "utilities", "blockchain"],
  "icons": [
    {
      "src": "/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Wallet",
      "short_name": "Wallet",
      "description": "Access blockchain wallet and transactions",
      "url": "/#wallet",
      "icons": [
        {
          "src": "/shortcut-wallet.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "PoP Tracker",
      "short_name": "PoP Tracker",
      "description": "Monitor proof of productivity metrics",
      "url": "/#pop-tracker",
      "icons": [
        {
          "src": "/shortcut-pop.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Tokens",
      "short_name": "Tokens",
      "description": "View cryptocurrency and DeFi positions",
      "url": "/#tokens",
      "icons": [
        {
          "src": "/shortcut-tokens.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Settings",
      "short_name": "Settings",
      "description": "Configure application preferences",
      "url": "/#settings",
      "icons": [
        {
          "src": "/shortcut-settings.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "file_handlers": [
    {
      "action": "/file-handler",
      "accept": {
        "text/csv": [".csv"],
        "application/json": [".json"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+sylos",
      "url": "/handle?protocol=%s"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "launch_handler": {
    "client_mode": "navigate-existing"
  }
}