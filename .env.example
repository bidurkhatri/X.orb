# ===========================================================
# X.orb — Environment Variables
# ===========================================================
# Copy to .env and fill in your values.
# This file documents ALL env vars used across the project.
# ===========================================================

# -----------------------------------------------------------
# Supabase (API + Dashboard)
# -----------------------------------------------------------

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Service role key — server-side only, full database access
SUPABASE_SERVICE_KEY=eyJ...

# Anon key — public, used by dashboard and client-side
SUPABASE_ANON_KEY=eyJ...

# -----------------------------------------------------------
# API Server (apps/api)
# -----------------------------------------------------------

# Secret for protecting /v1/cron/* endpoints (Vercel Cron)
CRON_SECRET=your_random_secret_here

# -----------------------------------------------------------
# Dashboard (apps/dashboard)
# -----------------------------------------------------------

# API base URL the dashboard talks to
VITE_API_URL=https://api.xorb.xyz

# Supabase credentials exposed to the browser (anon key only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# -----------------------------------------------------------
# Smart Contracts — Deployer (xorb-contracts)
# -----------------------------------------------------------

# Private key for contract deployment (NEVER commit the real key)
DEPLOYER_PRIVATE_KEY=0x...

# Alternative key name used by some deploy scripts
PRIVATE_KEY=0x...

# -----------------------------------------------------------
# RPC URLs
# -----------------------------------------------------------

# Base (primary deployment target)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Ethereum
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Polygon
POLYGON_RPC_URL=https://polygon-rpc.com/
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# -----------------------------------------------------------
# Block Explorer API Keys (for contract verification)
# -----------------------------------------------------------

BASESCAN_API_KEY=your_basescan_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# -----------------------------------------------------------
# Contract Deployment Configuration
# -----------------------------------------------------------

# Treasury wallet — receives protocol fees, slashed funds
TREASURY_ADDRESS=0x...

# Admin wallet — receives DEFAULT_ADMIN_ROLE on all contracts
ADMIN_ADDRESS=0x...

# Optional: pre-deployed USDC/token address (if not using standard USDC)
WXORB_ADDRESS=

# -----------------------------------------------------------
# Gas & Testing (xorb-contracts)
# -----------------------------------------------------------

# Enable gas usage reports during tests
REPORT_GAS=false

# CoinMarketCap API key for gas cost in USD
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# Min/max gas price in gwei (safety bounds)
MIN_GAS_PRICE=20
MAX_GAS_PRICE=1000

# Local development network
DEVELOPMENT_NETWORK=hardhat

# Test execution timeout in milliseconds
TEST_TIMEOUT=100000

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# -----------------------------------------------------------
# USDC Contract Addresses (reference — auto-selected by chain)
# -----------------------------------------------------------
# Base Mainnet:  0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia:  0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Polygon:       0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
