# ═══════════════════════════════════════
# X.orb — Environment Variables
# ═══════════════════════════════════════
# Copy to .env and fill in your values.

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...                    # Service role key (server-side only)
SUPABASE_ANON_KEY=eyJ...                       # Anon key (public, for dashboard)

# --- Smart Contracts (Base Chain) ---
DEPLOYER_PRIVATE_KEY=0x...                     # Deployer wallet private key
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=your_basescan_api_key

# --- Vercel Cron ---
CRON_SECRET=your_random_secret_here            # Protects /v1/cron/* endpoints

# --- Dashboard ---
VITE_API_URL=https://api.xorb.xyz              # API base URL for dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# --- USDC Contract Addresses (for reference) ---
# Base Mainnet:  0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia:  0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Polygon:       0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
