# Network Configuration
# Add your RPC URLs for different networks
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
POLYGON_RPC_URL=https://polygon-rpc.com/
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com/

# Deployment Configuration
# Private key for contract deployment (DO NOT COMMIT)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Etherscan API Keys for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Additional API Keys
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# Environment Configuration
# Set to true to enable gas reporting
REPORT_GAS=false

# Security Configuration
# Minimum gas price (in gwei)
MIN_GAS_PRICE=20

# Maximum gas price (in gwei)
MAX_GAS_PRICE=1000

# Development Configuration
# Network for local development
DEVELOPMENT_NETWORK=hardhat

# Timeout for test execution (in milliseconds)
TEST_TIMEOUT=100000

# Logging Configuration
LOG_LEVEL=info