{
  "name": "sylos-testing-framework",
  "version": "1.0.0",
  "description": "Comprehensive testing framework for SylOS Blockchain Operating System",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --config=jest.config.js --coverage",
    "test:integration": "jest --config=jest.config.js --testPathPattern=integration",
    "test:e2e": "echo 'E2E tests require browser environment'",
    "test:performance": "echo 'Performance tests require load testing tools'",
    "test:security": "npm run security:audit && npm run security:owasp",
    "test:contracts": "hardhat test",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:security",
    "test:comprehensive": "npm run test:all",
    "start:test": "serve -s dist -l 3000",
    "build:test": "npm run build && npm run start:test",
    "security:audit": "npm audit --audit-level moderate",
    "security:owasp": "npx owasp-dependency-check --project SylOS --scan .",
    "security:snyk": "snyk test",
    "security:bandit": "bandit -r ../sylos-blockchain-os/src",
    "security:eslint": "eslint ../sylos-blockchain-os/src --ext .ts,.tsx",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "generate-report": "mochawesome-merge reports/*.json > report.json && marge report.json --reportDir reports --inline",
    "clean": "rimraf coverage reports .nyc_output artifacts test-results",
    "clean:reports": "rimraf reports",
    "pretest": "npm run clean:reports",
    "test:watch": "jest --config=jest.config.js --watch --verbose",
    "test:coverage": "jest --config=jest.config.js --coverage --watchAll=false",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --config=jest.config.js --runInBand"
  },
  "dependencies": {
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.8",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.1",
    "cypress": "^13.6.0",
    "@cypress/react": "^5.12.4",
    "cypress-wait-until": "^2.0.1",
    "cypress-real-events": "^1.10.0",
    "playwright": "^1.40.0",
    "@playwright/test": "^1.40.0",
    "artillery": "^2.0.12",
    "lighthouse": "^11.4.0",
    "lighthouse-logger": "^1.4.2",
    "mocha": "^10.2.0",
    "chai": "^4.3.10",
    "supertest": "^6.3.3",
    "nock": "^13.4.0",
    "msw": "^2.0.8",
    "sinon": "^17.0.1",
    "hardhat": "^2.19.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "waffle": "^3.4.1",
    "truffle": "^5.11.5",

    "web3": "^4.3.0",
    "@metamask/detect-provider": "^2.0.0",
    "ethers": "^6.8.1",
    "@axe-core/playwright": "^4.8.2",
    "mongoose": "^8.0.3",
    "@types/mongoose": "^5.11.97",
    "cross-env": "^7.0.3",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "@types/mocha": "^10.0.6",
    "@types/chai": "^4.3.11",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "eslint-plugin-cypress": "^2.15.1",
    "eslint-plugin-jest": "^27.6.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.1.0",
    "typescript": "^5.2.2",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "serve": "^14.2.1",
    "rimraf": "^5.0.5",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "marge": "^6.0.0",
    "nyc": "^15.1.0",
    "coveralls": "^3.1.1",
    "codecov": "^3.8.3",
    "start-server-and-test": "^2.0.3",
    "owasp-dependency-check": "^1.10.0",
    "snyk": "^1.1200.0",
    "bandit": "^1.7.5",
    "puppeteer": "^21.5.2",
    "react-test-renderer": "^18.2.0",
    "@testing-library/react-hooks": "^8.0.1",
    "jest-runner-eslint": "^2.2.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/configs/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/../sylos-blockchain-os/src/$1",
      "\\.(css|less|scss|sass)$": "identity-obj-proxy"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/main.tsx",
      "!src/vite-env.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "cypress": {
    "baseUrl": "http://localhost:3000",
    "video": true,
    "screenshotOnRunFailure": true,
    "defaultCommandTimeout": 10000,
    "requestTimeout": 15000,
    "responseTimeout": 15000,
    "viewportWidth": 1280,
    "viewportHeight": 720
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}