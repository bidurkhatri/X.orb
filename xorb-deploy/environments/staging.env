# Staging Environment Configuration

# Network Configuration
NETWORK_NAME=Polygon Amoy Testnet
RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your_alchemy_key
CHAIN_ID=80002
CURRENCY_SYMBOL=MATIC
EXPLORER_URL=https://amoy.polygonscan.com
GAS_PRICE=30000000000

# Frontend Configuration
FRONTEND_URL=https://sylos-staging.example.com
API_URL=https://api-staging.sylos.example.com
IPFS_GATEWAY=https://ipfs-staging.sylos.example.com

# Database Configuration
DATABASE_URL=postgresql://stage_user:stage_password@staging-db:5432/sylos_staging
REDIS_URL=redis://staging-redis:6379/0

# Blockchain Configuration
CONTRACT_ADDRESS_FILE=$PWD/deployment/addresses/staging-addresses.json
DEPLOYER_PRIVATE_KEY=your_staging_deployer_private_key_here
VERIFIER_API_KEY=your_verifier_api_key_here

# IPFS Configuration
IPFS_PROJECT_ID=your_staging_ipfs_project_id
IPFS_PROJECT_SECRET=your_staging_ipfs_project_secret
IPFS_API_ENDPOINT=https://api.ipfs.io
IPFS_GATEWAY_DEFAULT=https://gateway.ipfs.io

# Mobile App Configuration
MOBILE_BUNDLE_ID=com.sylos.staging
MOBILE_APP_NAME=SylOS Staging
MOBILE_VERSION=0.2.0

# Build Configuration
BUILD_ENV=staging
NODE_ENV=staging
VITE_APP_ENV=staging

# Security Configuration
JWT_SECRET=your_jwt_secret_for_staging
ENCRYPTION_KEY=your_encryption_key_for_staging
API_RATE_LIMIT=5000

# Monitoring Configuration
LOG_LEVEL=info
SENTRY_DSN=https://your-staging-sentry-dsn-here
ANALYTICS_ID=your_staging_analytics_id

# External Services
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=your_staging_supabase_anon_key
SUPABASE_SERVICE_KEY=your_staging_supabase_service_key
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# SSL Configuration
SSL_CERT_PATH=/etc/ssl/certs/sylos-staging.crt
SSL_KEY_PATH=/etc/ssl/private/sylos-staging.key

# CDN Configuration
CDN_URL=https://cdn-staging.sylos.example.com
CLOUDFLARE_API_TOKEN=your_cloudflare_token
CLOUDFLARE_ZONE_ID=your_zone_id