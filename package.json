{
  "name": "sylos-code-quality",
  "version": "1.0.0",
  "description": "Code quality configuration and tools for SylOS Blockchain OS",
  "main": "index.js",
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:check": "eslint . --ext .ts,.tsx,.js,.jsx --format json --output-file reports/eslint-report.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml,sol}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml,sol}\"",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "test": "jest --coverage",
    "test:watch": "jest --coverage --watch",
    "test:ci": "jest --ci --coverage --watchAll=false --reporters=default --reporters=jest-junit",
    "test:unit": "jest --testPathPattern=unit --coverage",
    "test:integration": "jest --testPathPattern=integration --coverage",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:visual": "playwright test",
    "test:accessibility": "playwright test accessibility/",
    "test:performance": "lighthouse-ci autorun",
    "test:security": "npm run security:audit && npm run security:audit:contracts",
    "test:contracts": "hardhat test",
    "test:contracts:coverage": "hardhat coverage",
    "test:all": "npm run typecheck && npm run lint && npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:contracts",
    "test:ci:all": "npm run typecheck && npm run lint:check && npm run test:ci && npm run test:contracts:coverage",
    
    "security:audit": "npm audit --audit-level moderate",
    "security:audit:fix": "npm audit fix",
    "security:audit:contracts": "npm audit --prefix smart-contracts",
    "security:scan": "snyk test",
    "security:scan:fix": "snyk test --fix",
    "security:sca": "npm-check-updates",
    "security:owasp": "owasp-dependency-check --project SylOS --scan .",
    "security:licenses": "license-checker --onlyAllow 'MIT;Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;Unlicense'",
    
    "deps:update": "npm-check-updates --upgrade",
    "deps:update:dry": "npm-check-updates --upgrade --dry-run",
    "deps:audit": "npm audit --json | audit-ci --moderate",
    "deps:license": "license-checker --json > reports/licenses.json",
    
    "build:analyze": "npm run build && npx webpack-bundle-analyzer dist/static/js/*.js",
    "build:profile": "npm run build -- --profile",
    "build:stats": "npm run build -- --stats=detailed",
    
    "performance:analyze": "lighthouse-ci autorun",
    "performance:profile": "node --prof src/index.js",
    "performance:profile:node": "node --prof --trace-warnings src/index.js",
    "performance:inspect": "node --inspect src/index.js",
    "memory:leak": "node --expose-gc --inspect src/index.js",
    "memory:profile": "node --expose-gc --max-old-space-size=4096 --inspect src/index.js",
    
    "bundle:analyze": "webpack-bundle-analyzer dist/static/js/*.js",
    "bundle:size": "bundlesize",
    "bundle:compare": "bundlesize --compare",
    
    "docs:generate": "typedoc",
    "docs:build": "gitbook build docs docs-build",
    "docs:serve": "gitbook serve docs docs-build",
    
    "prepare:hooks": "husky install",
    "prepare:git": "git init && git add . && git commit -m 'Initial commit with code quality setup' || true",
    
    "clean": "rimraf dist coverage reports .nyc_output .eslintcache node_modules/.cache",
    "clean:cache": "rimraf .eslintcache .jestcache .nyc_output node_modules/.cache",
    "clean:build": "rimraf dist build",
    "clean:reports": "rimraf reports",
    
    "commit": "git-cz",
    "release": "standard-version",
    "release:dry": "standard-version --dry-run",
    
    "report:coverage": "codecov",
    "report:junit": "junit-viewer --results=reports/junit.xml --save=reports/junit.html",
    "report:html": "serve reports -l 4000"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/utils": "^7.0.0",
    "@typescript-eslint/type-utils": "^7.0.0",
    
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-import-helpers": "^1.3.1",
    "eslint-plugin-jsdoc": "^48.0.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-react-native-a11y": "^3.3.0",
    "eslint-plugin-security": "^2.1.1",
    "eslint-plugin-sonarjs": "^0.24.0",
    "eslint-plugin-unicorn": "^50.0.0",
    "eslint-plugin-etc": "^2.0.2",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-better-styled-components": "^1.1.2",
    "eslint-plugin-cypress": "^2.15.1",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-vitest": "^0.4.0",
    
    "prettier": "^3.2.0",
    "prettier-plugin-embed": "^0.5.0",
    "prettier-plugin-package": "^1.3.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "prettier-plugin-solidity": "^1.1.3",
    
    "typescript": "^5.3.0",
    "typedoc": "^0.25.0",
    "typedoc-plugin-markdown": "^4.0.0",
    
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-watch-typeahead": "^2.2.0",
    "jest-runner-eslint": "^2.2.0",
    "jest-junit": "^16.0.0",
    "jest-html-reporters": "^3.1.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.10.0",
    
    "cypress": "^13.6.0",
    "@cypress/react": "^7.0.0",
    "cypress-wait-until": "^2.0.1",
    "cypress-real-events": "^1.12.0",
    "cypress-file-upload": "^5.0.8",
    "cypress-axe": "^1.5.0",
    
    "playwright": "^1.40.0",
    "@playwright/test": "^1.40.0",
    "@axe-core/playwright": "^4.8.0",
    
    "lighthouse": "^11.4.0",
    "@lighthouse-ci/cli": "^0.12.0",
    "lighthouse-ci-action": "^0.0.1",
    
    "bundlesize": "^0.18.2",
    "webpack-bundle-analyzer": "^4.10.0",
    "rollup-plugin-visualizer": "^5.9.0",
    
    "snyk": "^1.1263.0",
    "audit-ci": "^6.6.0",
    "owasp-dependency-check": "^1.10.0",
    "license-checker": "^25.0.1",
    "npm-check-updates": "^16.14.0",
    
    "husky": "^8.0.0",
    "lint-staged": "^15.2.0",
    "@commitlint/cli": "^18.4.0",
    "commitlint-config-conventional": "^18.4.0",
    "commitizen": "^4.3.0",
    "standard-version": "^9.5.0",
    "git-cz": "^4.9.0",
    
    "rimraf": "^5.0.0",
    "serve": "^14.2.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.2.0",
    "start-server-and-test": "^2.0.0",
    
    "artillery": "^2.0.0",
    "@artillery/plugin-metrics-by-endpoint": "^1.0.0",
    
    "puppeteer": "^21.5.0",
    "sharp": "^0.33.0",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    
    "@types/puppeteer": "^7.0.0",
    "@types/pixelmatch": "^5.2.0",
    "@types/pngjs": "^6.0.0",
    
    "cross-env": "^7.0.3",
    "codecov": "^3.8.3",
    "coveralls": "^3.1.1",
    "nyc": "^15.1.0",
    
    "better-npm-run": "^0.1.1",
    "cross-var": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.sol": [
      "prettier --write",
      "solhint"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-push": "npm run typecheck && npm run test:unit"
    }
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/__tests__/**/*.{js,ts,tsx}",
      "**/*.{test,spec}.{js,ts,tsx}"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,ts,tsx}",
      "!src/**/*.d.ts",
      "!src/main.tsx",
      "!src/vite-env.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 85,
        "functions": 85,
        "lines": 85,
        "statements": 85
      }
    },
    "coverageReporters": [
      "text",
      "text-summary",
      "lcov",
      "html",
      "json"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "reports",
          "outputName": "junit.xml"
        }
      ],
      [
        "jest-html-reporters",
        {
          "publicPath": "reports",
          "filename": "report.html"
        }
      ]
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "scope-case": [
        2,
        "always",
        "kebab-case"
      ],
      "type-enum": [
        2,
        "always",
        [
          "feat",
          "fix",
          "docs",
          "style",
          "refactor",
          "perf",
          "test",
          "build",
          "ci",
          "chore",
          "revert"
        ]
      ]
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}