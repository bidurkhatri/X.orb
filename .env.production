POLYGON_PAYMASTER=0xAe1418F0a941a13DA8bC689Df7B3b4f7b4E21583

# ========================================
# DEPLOYMENT CONFIGURATION
# ========================================
DEPLOY_ENV=production
DEPLOY_TIMESTAMP=2025-11-11T11:45:00Z
BUILD_NUMBER=1
GIT_COMMIT=production
