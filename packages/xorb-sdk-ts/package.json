{
  "name": "xorb-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for X.orb — Agent Trust Infrastructure API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "repository": { "type": "git", "url": "https://github.com/bidurkhatri/X.orb" },
  "homepage": "https://xorb.xyz",
  "author": "Fintex",
  "files": ["dist", "README.md", "package.json"],
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["xorb", "ai-agents", "trust", "reputation", "x402"],
  "license": "MIT"
}
