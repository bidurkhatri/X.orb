{
  "name": "xorb-sdk",
  "version": "0.3.0",
  "description": "TypeScript SDK for X.orb — Agent Trust Infrastructure API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --external ethers",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bidurkhatri/X.orb"
  },
  "homepage": "https://xorb.xyz",
  "author": "Bidur Khatri <bidur@fintex.com.au>",
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "@x402/core": "^2.7.0",
    "@x402/evm": "^2.7.0",
    "@x402/fetch": "^2.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "xorb",
    "ai-agents",
    "trust",
    "reputation",
    "x402"
  ],
  "license": "MIT"
}
