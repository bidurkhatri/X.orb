# Development Environment Configuration

# Network Configuration
NETWORK_NAME=Polygon Mumbai Testnet
RPC_URL=https://rpc-mumbai.maticvigil.com
CHAIN_ID=80001
CURRENCY_SYMBOL=MATIC
EXPLORER_URL=https://mumbai.polygonscan.com
GAS_PRICE=30000000000

# Frontend Configuration
FRONTEND_URL=https://sylos-dev.example.com
API_URL=https://api-dev.sylos.example.com
IPFS_GATEWAY=https://ipfs-dev.sylos.example.com

# Database Configuration
DATABASE_URL=postgresql://dev_user:dev_password@localhost:5432/sylos_dev
REDIS_URL=redis://localhost:6379/0

# Blockchain Configuration
CONTRACT_ADDRESS_FILE=$PWD/deployment/addresses/dev-addresses.json
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here
VERIFIER_API_KEY=your_verifier_api_key_here

# IPFS Configuration
IPFS_PROJECT_ID=your_ipfs_project_id
IPFS_PROJECT_SECRET=your_ipfs_project_secret
IPFS_API_ENDPOINT=https://api.ipfs.io
IPFS_GATEWAY_DEFAULT=https://gateway.ipfs.io

# Mobile App Configuration
MOBILE_BUNDLE_ID=com.sylos.dev
MOBILE_APP_NAME=SylOS Dev
MOBILE_VERSION=0.1.0

# Build Configuration
BUILD_ENV=development
NODE_ENV=development
VITE_APP_ENV=development

# Security Configuration
JWT_SECRET=your_jwt_secret_for_dev
ENCRYPTION_KEY=your_encryption_key_for_dev
API_RATE_LIMIT=1000

# Monitoring Configuration
LOG_LEVEL=debug
SENTRY_DSN=https://your-sentry-dsn-here
ANALYTICS_ID=your_analytics_id

# External Services
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key