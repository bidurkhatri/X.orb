# Production Environment Configuration

# Network Configuration
NETWORK_NAME=Polygon Mainnet
RPC_URL=https://polygon-rpc.com
CHAIN_ID=137
CURRENCY_SYMBOL=MATIC
EXPLORER_URL=https://polygonscan.com
GAS_PRICE=30000000000

# Frontend Configuration
FRONTEND_URL=https://sylos.io
API_URL=https://api.sylos.io
IPFS_GATEWAY=https://ipfs.sylos.io

# Database Configuration
DATABASE_URL=postgresql://prod_user:secure_password@prod-db-cluster:5432/sylos_production
REDIS_URL=redis://prod-redis-cluster:6379/0

# Blockchain Configuration
CONTRACT_ADDRESS_FILE=$PWD/deployment/addresses/production-addresses.json
DEPLOYER_PRIVATE_KEY=your_production_deployer_private_key_here
VERIFIER_API_KEY=your_production_verifier_api_key_here

# IPFS Configuration
IPFS_PROJECT_ID=your_production_ipfs_project_id
IPFS_PROJECT_SECRET=your_production_ipfs_project_secret
IPFS_API_ENDPOINT=https://api.ipfs.io
IPFS_GATEWAY_DEFAULT=https://gateway.ipfs.io

# Mobile App Configuration
MOBILE_BUNDLE_ID=com.sylos
MOBILE_APP_NAME=SylOS
MOBILE_VERSION=1.0.0

# Build Configuration
BUILD_ENV=production
NODE_ENV=production
VITE_APP_ENV=production

# Security Configuration
JWT_SECRET=your_secure_jwt_secret_for_production
ENCRYPTION_KEY=your_secure_encryption_key_for_production
API_RATE_LIMIT=10000
ENABLE_RATE_LIMITING=true
ENABLE_CORS=true
CORS_ORIGINS=https://sylos.io,https://app.sylos.io

# Monitoring Configuration
LOG_LEVEL=warn
SENTRY_DSN=https://your-production-sentry-dsn-here
ANALYTICS_ID=your_production_analytics_id
ENABLE_MONITORING=true
HEALTH_CHECK_URL=https://health.sylos.io

# External Services
SUPABASE_URL=https://your-production-project.supabase.co
SUPABASE_ANON_KEY=your_production_supabase_anon_key
SUPABASE_SERVICE_KEY=your_production_supabase_service_key
PINATA_API_KEY=your_production_pinata_api_key
PINATA_SECRET_KEY=your_production_pinata_secret_key

# SSL Configuration
SSL_CERT_PATH=/etc/ssl/certs/sylos.crt
SSL_KEY_PATH=/etc/ssl/private/sylos.key
ENABLE_HTTPS=true
FORCE_HTTPS=true

# CDN Configuration
CDN_URL=https://cdn.sylos.io
CLOUDFLARE_API_TOKEN=your_cloudflare_production_token
CLOUDFLARE_ZONE_ID=your_production_zone_id
ENABLE_CDN=true

# Backup Configuration
BACKUP_S3_BUCKET=sylos-production-backups
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
BACKUP_RETENTION_DAYS=30

# Performance Configuration
ENABLE_CACHING=true
CACHE_TTL=3600
MAX_CONNECTIONS=1000
WORKER_PROCESSES=4

# Security Headers
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
X_XSS_PROTECTION=1; mode=block
STRICT_TRANSPORT_SECURITY=max-age=31536000; includeSubDomains

# Load Balancer Configuration
LOAD_BALANCER_URL=https://lb.sylos.io
ENABLE_LOAD_BALANCING=true
HEALTH_CHECK_INTERVAL=30